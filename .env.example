# ── Anthropic Claude API (AI Adviser + WhatsApp bot) ─────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── WhatsApp Cloud API (Meta Developer Console) ───────────────────
# Get from: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_VERIFY_TOKEN=agriassist_verify
PHONE_NUMBER_ID=your_phone_number_id_here

# ── Streamlit Web App URL ─────────────────────────────────────────
WEB_APP_URL=https://your-app.streamlit.app

# ── MySQL Database (optional — app works without it) ─────────────
# Leave blank to run without a database (Streamlit Cloud mode)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=agriassist

# ── Weather API (Open-Meteo — FREE, no key needed) ───────────────
WEATHER_API_BASE=https://api.open-meteo.com/v1/forecast

